generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum SystemRole {
  COMPANY_ADMIN
  HR_MANAGER
  TEAM_LEAD
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// Which public signup/login portal this account belongs to (enforced at login).
enum SignupPortal {
  ADMIN_PORTAL
  EMPLOYEE_PORTAL
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
}

enum LeaveRequestStatus {
  PENDING_TEAM_LEAD
  PENDING_HR
  APPROVED
  REJECTED
  CANCELLED
}

enum PayrollStatus {
  DRAFT
  PROCESSED
  PAID
}

enum LeaveBalancePeriod {
  YEARLY
  MONTHLY
}

model User {
  id                   Int            @id @default(autoincrement())
  email                String         @unique
  passwordHash         String
  firstName            String?
  lastName             String?
  role                 Role           @default(USER)
  systemRole           SystemRole     @default(EMPLOYEE)
  signupPortal         SignupPortal   @default(EMPLOYEE_PORTAL)
  status               UserStatus     @default(ACTIVE)
  isActive             Boolean        @default(true)
  isEmailVerified      Boolean        @default(false)
  lastLoginAt          DateTime?
  deletedAt            DateTime?
  passwordResetToken   String?        @unique
  passwordResetExpiry  DateTime?
  emailVerifyToken     String?        @unique
  emailVerifyExpiry    DateTime?
  companyId            String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  refreshTokens        RefreshToken[]
  company              Company?       @relation(fields: [companyId], references: [id])
  employeeProfile      Employee?
  auditLogs            AuditLog[]
  uploadedDocuments    EmployeeDocument[]

  @@map("users")
  @@index([companyId])
  @@index([systemRole])
  @@index([status])
}

model Company {
  id          String      @id @default(uuid())
  name        String
  slug        String      @unique
  email       String?
  phone       String?
  timezone    String      @default("UTC")
  logoUrl     String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  users       User[]
  departments Department[]
  teams       Team[]
  branches    Branch[]
  employees   Employee[]
  attendanceRecords AttendanceRecord[]
  leaveRequests     LeaveRequest[]
  payrollRecords    PayrollRecord[]
  notifications     Notification[]
  leavePolicies      LeavePolicy[]
  leaveBalances      LeaveBalance[]
  payrollCycles      PayrollCycle[]
  payrollRevisions   PayrollRevision[]
  documents          EmployeeDocument[]
}

model Department {
  id          String    @id @default(uuid())
  companyId   String
  name        String
  code        String?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees   Employee[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Team {
  id          String    @id @default(uuid())
  companyId   String
  name        String
  code        String?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees   Employee[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Branch {
  id        String    @id @default(uuid())
  companyId String
  name      String
  code      String?
  city      String?
  country   String?
  timezone  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Employee {
  id                 String      @id @default(uuid())
  userId             Int         @unique
  companyId          String
  employeeCode       String
  departmentId       String?
  teamId             String?
  branchId           String?
  jobTitle           String?
  joiningDate        DateTime?
  confirmationDate   DateTime?
  leavingDate        DateTime?
  managerEmployeeId  String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  company            Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department         Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  team               Team?       @relation(fields: [teamId], references: [id], onDelete: SetNull)
  branch             Branch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  attendanceRecords  AttendanceRecord[]
  leaveRequests      LeaveRequest[]
  payrollRecords     PayrollRecord[]
  notifications      Notification[]
  leaveBalances      LeaveBalance[]
  payrollRevisions   PayrollRevision[]
  documents          EmployeeDocument[]

  @@unique([companyId, employeeCode])
  @@index([companyId])
  @@index([departmentId])
  @@index([teamId])
  @@index([branchId])
}

model LeavePolicy {
  id                 String            @id @default(uuid())
  companyId          String
  leaveType          String
  annualAllocation   Float
  carryForwardMax    Float             @default(0)
  period             LeaveBalancePeriod @default(YEARLY)
  requiresTeamLead   Boolean           @default(true)
  requiresHrApproval Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  company            Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, leaveType])
  @@index([companyId])
}

model LeaveBalance {
  id             String   @id @default(uuid())
  employeeId     String
  companyId      String
  leaveType      String
  year           Int
  allocatedDays  Float    @default(0)
  usedDays       Float    @default(0)
  remainingDays  Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([employeeId, leaveType, year])
  @@index([companyId, year])
}

model AttendanceRecord {
  id          String           @id @default(uuid())
  employeeId  String
  companyId   String
  date        DateTime
  clockInAt   DateTime?
  clockOutAt  DateTime?
  workedMins  Int              @default(0)
  status      AttendanceStatus @default(PRESENT)
  remarks     String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([companyId, date])
}

model LeaveRequest {
  id               String             @id @default(uuid())
  employeeId       String
  companyId        String
  leaveType        String
  reason           String?
  startDate        DateTime
  endDate          DateTime
  totalDays        Float
  status           LeaveRequestStatus @default(PENDING_TEAM_LEAD)
  teamLeadComments String?
  hrComments       String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  employee         Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company          Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([employeeId, startDate])
}

model PayrollRecord {
  id           String        @id @default(uuid())
  employeeId   String
  companyId    String
  payrollMonth String
  basicSalary  Decimal       @db.Decimal(12, 2)
  allowances   Decimal       @default(0) @db.Decimal(12, 2)
  deductions   Decimal       @default(0) @db.Decimal(12, 2)
  netPay       Decimal       @db.Decimal(12, 2)
  status       PayrollStatus @default(DRAFT)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  employee     Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  revisions    PayrollRevision[]

  @@unique([employeeId, payrollMonth])
  @@index([companyId, payrollMonth])
}

model PayrollCycle {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  month       String
  periodStart DateTime
  periodEnd   DateTime
  status      PayrollStatus @default(DRAFT)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, month])
}

model PayrollRevision {
  id             String   @id @default(uuid())
  payrollRecordId String
  employeeId     String
  companyId      String
  reason         String
  amountDelta    Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now())
  payrollRecord  PayrollRecord @relation(fields: [payrollRecordId], references: [id], onDelete: Cascade)
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
}

model EmployeeDocument {
  id           String   @id @default(uuid())
  employeeId   String
  companyId    String
  category     String
  fileName     String
  mimeType     String
  fileSize     Int
  storagePath  String
  uploadedById Int?
  createdAt    DateTime @default(now())
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([employeeId, createdAt])
  @@index([companyId, category])
}

model Notification {
  id         String   @id @default(uuid())
  employeeId String
  companyId  String
  title      String
  message    String
  type       String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([employeeId, createdAt])
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId Int?
  action      String
  resource    String
  resourceId  String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([resource, resourceId])
  @@index([createdAt])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  tokenHash String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}
