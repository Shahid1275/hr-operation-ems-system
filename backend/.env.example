PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/employee_management_system?schema=public

JWT_SECRET=replace_with_strong_access_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
JWT_EXPIRES_IN=15m

REDIS_URL=redis://localhost:6379
ENABLE_REDIS=true
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=

CORS_ORIGINS=http://localhost:3001,http://localhost:3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
REQUIRE_EMAIL_VERIFICATION=false

# Leave SMTP_HOST empty for dev (tokens logged to console only).
# Gmail example (use App Password, not your normal password):
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
# Quote if the app password has spaces: SMTP_PASS="xxxx xxxx xxxx xxxx"
SMTP_PASS=
MAIL_FROM=
MAIL_FROM_NAME=Employee Management System
